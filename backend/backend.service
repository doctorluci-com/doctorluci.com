[Unit]
Description=Dr. Lucia Gariuc — Appointment Backend
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/doctorluci.com/backend
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kids-of-lucia-backend
EnvironmentFile=/var/www/doctorluci.com/backend/.env

[Install]
WantedBy=multi-user.target
